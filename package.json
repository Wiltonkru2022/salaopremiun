{
  "name": "salaopremium",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "next typegen && node scripts/ensure-next-types.mjs && tsc --noEmit --incremental false",
    "audit": "npm audit --audit-level=moderate",
    "audit:service-role": "node scripts/audit/service-role-audit.mjs",
    "audit:admin-actions": "node scripts/audit/admin-master-actions-audit.mjs",
    "e2e:proxy": "node scripts/e2e/proxy-smoke.mjs",
    "e2e:sales": "node scripts/e2e/saas-sales-flow.mjs",
    "check": "npm run lint && npm run typecheck",
    "validate": "npm run lint && npm run typecheck && npm run audit && npm run audit:service-role && npm run audit:admin-actions && npm run build",
    "validate:release": "npm run validate && npm run e2e:proxy && npm run e2e:sales"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "openai": "^6.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "globals": "^17.4.0",
    "supabase": "^2.91.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
